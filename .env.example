# Bridge Aggregator — Backend Environment Variables
#
# Copy to .env and fill in real values. All vars are optional unless marked REQUIRED.
# Viper reads these in uppercase or snake_case; either form works.
#
# Quick start (mainnet):
#   cp .env.example .env
#   # Fill in DATABASE_URL, BLOCKDAEMON_API_KEY, and ACROSS_DEPOSITOR at minimum
#   go run ./cmd/server
#
# Testnet mode:
#   NETWORK=testnet go run ./cmd/server
#   (or use scripts/run-testnet.sh)

# ── Server ─────────────────────────────────────────────────────────────────────

PORT=8080
# "mainnet" (default) or "testnet"
NETWORK=mainnet

# ── Database (optional) ────────────────────────────────────────────────────────
# Required for /execute and /operations endpoints. If unset, those endpoints return 503.
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ── RPC URLs ───────────────────────────────────────────────────────────────────
# General-purpose mainnet RPC (used when a specific chain RPC is not set).
# RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY

# Testnet RPC endpoints — only used when NETWORK=testnet.
# Defaults are public free-tier endpoints; override for reliability.
# SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
# BASE_SEPOLIA_RPC_URL=https://base-sepolia.infura.io/v3/YOUR_KEY
# ARBITRUM_SEPOLIA_RPC_URL=https://arbitrum-sepolia.infura.io/v3/YOUR_KEY
# OP_SEPOLIA_RPC_URL=https://optimism-sepolia.infura.io/v3/YOUR_KEY

# ── Across Bridge ──────────────────────────────────────────────────────────────
# ACROSS_API_URL defaults to:
#   mainnet -> https://app.across.to/api
#   testnet -> https://testnet.across.to/api
# ACROSS_API_URL=
# ACROSS_API_KEY=
# ACROSS_DEPOSITOR=0xYourWalletAddress   # wallet used as depositor in Across quotes (REQUIRED for Across)

# ── Stargate (LayerZero) ───────────────────────────────────────────────────────
# STARGATE_API_URL=https://transfer.layerzero-api.com/v1
# STARGATE_API_KEY=

# ── Blockdaemon ────────────────────────────────────────────────────────────────
BLOCKDAEMON_API_KEY=
# BLOCKDAEMON_API_URL=https://svc.blockdaemon.com

# ── Circle CCTP Attestation ────────────────────────────────────────────────────
# Mainnet: https://iris.circle.com (default)
# Testnet: https://iris-api-sandbox.circle.com
# CCTP_ATTESTATION_URL=https://iris.circle.com

# ── Uniswap Trading API ────────────────────────────────────────────────────────
UNISWAP_API_KEY=
# UNISWAP_API_URL=https://trade-api.gateway.uniswap.org/v1
UNISWAP_SWAPPER_WALLET=   # wallet address for Uniswap swap tx building (from=)

# ── 0x Protocol ───────────────────────────────────────────────────────────────
ZEROEX_API_KEY=
# ZEROEX_API_URL=https://api.0x.org
# ZEROEX_TAKER=   # taker address; falls back to UNISWAP_SWAPPER_WALLET if unset

# ── 1inch ──────────────────────────────────────────────────────────────────────
ONEINCH_API_KEY=
# ONEINCH_API_URL=https://api.1inch.com
# ONEINCH_API_VERSION=v6.1
# ONEINCH_SWAPPER=   # wallet for 1inch swap tx building; falls back to UNISWAP_SWAPPER_WALLET

# ── Intent Parsing (LLM) ───────────────────────────────────────────────────────
# Provider preference: Gemini first, OpenRouter fallback.
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# OPENROUTER_KEY=

# ── API auth ───────────────────────────────────────────────────────────────────
# Required in production for mutating endpoints.
# API_KEY=
