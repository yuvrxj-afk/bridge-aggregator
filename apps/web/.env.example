# ── DEPLOYMENT NOTE ───────────────────────────────────────────────────────────
# All VITE_* vars are baked into the JS bundle at build time (not runtime).
# In Docker: pass as --build-arg. In docker-compose: set in your .env file.
# Missing VITE_API_URL → all API calls silently fail against localhost:8080.
# Missing VITE_WALLETCONNECT_PROJECT_ID → WalletConnect QR codes won't work.
# ──────────────────────────────────────────────────────────────────────────────

# App metadata
VITE_APP_NAME=TERMINAL.AGG

# Backend API URL — MUST be set for production (default is localhost:8080)
VITE_API_URL=http://localhost:8080

# Wallet connection — get a project ID at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# RPC endpoints (recommended: use your own provider to avoid rate limits in production)
# All chains are registered in wagmi regardless of VITE_NETWORK — enables runtime switching.
VITE_RPC_MAINNET=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID
VITE_RPC_POLYGON=https://polygon-mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID
VITE_RPC_OPTIMISM=https://optimism-mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID
VITE_RPC_ARBITRUM=https://arbitrum-mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID
VITE_RPC_BASE=https://base-mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Testnet mode — set VITE_NETWORK=testnet to default the UI to testnet chains.
# The toggle in the UI can switch between mainnet/testnet at runtime regardless of this value.
# VITE_NETWORK=testnet
# VITE_RPC_SEPOLIA=
# VITE_RPC_BASE_SEPOLIA=
# VITE_RPC_ARBITRUM_SEPOLIA=
# VITE_RPC_OP_SEPOLIA=
# Backend must also be running with NETWORK=testnet (use scripts/run-testnet.sh)
