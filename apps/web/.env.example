# ── DEPLOYMENT NOTE ───────────────────────────────────────────────────────────
# VITE_* vars are baked into the JS bundle at build time.
# In docker-compose: only VITE_WALLETCONNECT_PROJECT_ID is required.
# API calls use relative paths (/api/v1/...) — nginx in the web container
# proxies them to the api and api-testnet backend services automatically.
# ──────────────────────────────────────────────────────────────────────────────

# Wallet connection — get a project ID at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# ── LOCAL DEV ONLY ────────────────────────────────────────────────────────────
# In dev (bun run dev), the Vite proxy forwards /api → :8080 and /api/testnet → :8081.
# VITE_API_URL and VITE_API_URL_TESTNET are only needed if running a remote backend
# instead of local. Leave unset for local development.
# VITE_API_URL=http://localhost:8080
# VITE_API_URL_TESTNET=http://localhost:8081

# RPC endpoints (optional — falls back to public RPCs if unset)
# VITE_RPC_MAINNET=https://mainnet.infura.io/v3/YOUR_KEY
# VITE_RPC_POLYGON=https://polygon-mainnet.infura.io/v3/YOUR_KEY
# VITE_RPC_OPTIMISM=https://optimism-mainnet.infura.io/v3/YOUR_KEY
# VITE_RPC_ARBITRUM=https://arbitrum-mainnet.infura.io/v3/YOUR_KEY
# VITE_RPC_BASE=https://base-mainnet.infura.io/v3/YOUR_KEY
# VITE_RPC_SEPOLIA=
# VITE_RPC_BASE_SEPOLIA=
